---
const features = [
	{
		title: "Multi-database support",
		description: "PostgreSQL, SQLite, Redis, and ClickHouse — every engine in one consistent interface. No context-switching between five different apps.",
		icon: "M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75",
	},
	{
		title: "Schema visualizer",
		description: "Interactive ER diagrams render your table relationships automatically. See the shape of your data, not just the rows.",
		icon: "M7.5 14.25v2.25m3-4.5v4.5m3-6.75v6.75m3-9v9M6 20.25h12A2.25 2.25 0 0020.25 18V6A2.25 2.25 0 0018 3.75H6A2.25 2.25 0 003.75 6v12A2.25 2.25 0 006 20.25z",
	},
	{
		title: "AI-powered SQL",
		description: "Describe what you need in plain English and watch the query stream into the editor — schema-aware, ready to run.",
		icon: "M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456z",
	},
	{
		title: "Command palette",
		description: "Jump to any table, connection, or action with a keystroke. Keyboard-first, mouse-optional — built for speed.",
		icon: "M6.75 7.5l3 2.25-3 2.25m4.5 0h3m-9 8.25h13.5A2.25 2.25 0 0021 18V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6v12a2.25 2.25 0 002.25 2.25z",
	},
	{
		title: "SSH tunnel support",
		description: "Reach databases behind a bastion securely. Password or private key — configured once, connected instantly.",
		icon: "M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z",
	},
	{
		title: "Native & lightweight",
		description: "Built with Tauri, not Electron. A few megabytes, instant startup, and your credentials never leave the machine.",
		icon: "M13 16.5l3-3m0 0-3-3m3 3H8m13 0a9 9 0 11-18 0 9 9 0 0118 0z",
	},
];
---

<section id="features" class="capabilities">
	<div class="section-heading section-heading-split">
		<div>
			<p class="eyebrow">Capability index</p>
			<h2>Everything you need.<br />Nothing you don't.</h2>
		</div>
		<p>A focused tool for developers who would rather query than configure.</p>
	</div>

	<div class="capability-list">
		{features.map((feature, index) => (
			<div class="capability-row">
				<span class="capability-index">{String(index + 1).padStart(2, "0")}</span>
				<h3>{feature.title}</h3>
				<p>{feature.description}</p>
				<svg class="capability-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.35" aria-hidden="true">
					<path stroke-linecap="round" stroke-linejoin="round" d={feature.icon}></path>
				</svg>
			</div>
		))}
	</div>
</section>

<style>
	.capabilities {
		border-bottom: 1px solid var(--line);
		padding-block: clamp(80px, 7.5vw, 108px);
	}

	.capability-list {
		border-top: 1px solid var(--line-strong);
	}

	.capability-row {
		display: grid;
		min-height: 112px;
		align-items: center;
		grid-template-columns: 64px minmax(200px, 0.7fr) minmax(300px, 1.3fr) 32px;
		gap: 28px;
		border-bottom: 1px solid var(--line);
		padding: 24px 16px;
		transition: background 180ms ease, padding 180ms ease;
	}

	.capability-row:hover {
		background: var(--cyan-wash);
		padding-inline: 24px;
	}

	.capability-index {
		color: var(--cyan);
		font-family: var(--font-mono);
		font-size: 0.74rem;
	}

	.capability-row h3 {
		margin: 0;
		color: var(--ink);
		font-size: 1.32rem;
		font-weight: 650;
		letter-spacing: -0.025em;
	}

	.capability-row p {
		max-width: 690px;
		margin: 0;
		color: var(--ink-soft);
		font-size: 0.9rem;
		line-height: 1.65;
	}

	.capability-icon {
		width: 25px;
		height: 25px;
		color: var(--ink-faint);
		transition: color 180ms ease;
	}

	.capability-row:hover .capability-icon {
		color: var(--cyan-bright);
	}

	@media (max-width: 900px) {
		.capability-row {
			grid-template-columns: 46px minmax(180px, 0.8fr) minmax(260px, 1.2fr) 28px;
			gap: 18px;
		}
	}

	@media (max-width: 640px) {
		.capability-row {
			min-height: 0;
			grid-template-columns: 36px 1fr 24px;
			gap: 12px;
			padding: 22px 8px;
		}

		.capability-row p {
			grid-column: 2 / -1;
			font-size: 0.82rem;
		}

		.capability-row:hover {
			padding-inline: 12px;
		}
	}
</style>
