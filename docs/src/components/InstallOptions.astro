---
const { compact = false } = Astro.props;
const instance = compact ? "install-final" : "install-hero";
---

<div class:list={["install-options", { compact }]}>
	<div class="install-method" role="group" aria-label="Install method">
		<input
			class="install-radio install-radio-brew"
			type="radio"
			name={instance}
			id={`${instance}-brew`}
			checked
		/>
		<label class="install-tab" for={`${instance}-brew`}>Homebrew</label>

		<input
			class="install-radio install-radio-manual"
			type="radio"
			name={instance}
			id={`${instance}-manual`}
		/>
		<label class="install-tab" for={`${instance}-manual`}>Manual</label>

		<div class="install-panels">
			<div class="install-panel install-panel-brew">
				<p class="install-caption">Recommended</p>
				<code class="install-command"><span>$</span> brew install --cask --force amalshaji/taps/dbcooper</code>
			</div>

			<div class="install-panel install-panel-manual">
				<a
					class="manual-download"
					href="https://github.com/amalshaji/dbcooper/releases/latest"
					target="_blank"
					rel="noreferrer"
				>
					<svg viewBox="0 0 24 24" aria-hidden="true">
						<path d="M12 3v12m0 0 5-5m-5 5-5-5M5 21h14"></path>
					</svg>
					<span>Download .dmg</span>
				</a>
				<code class="install-command"><span>$</span> xattr -cr /Applications/DBcooper.app</code>
			</div>
		</div>
	</div>

	<p class="install-meta">Apple Silicon · Free &amp; open source</p>
</div>

<style>
	.install-options {
		width: min(100%, 520px);
		margin-top: 30px;
	}

	.install-options.compact {
		margin-top: 0;
	}

	.install-method {
		display: flex;
		flex-wrap: wrap;
		gap: 5px;
	}

	.install-radio {
		position: absolute;
		width: 1px;
		height: 1px;
		overflow: hidden;
		opacity: 0;
		pointer-events: none;
	}

	.install-tab {
		border: 1px solid var(--line);
		border-radius: 4px;
		color: var(--ink-faint);
		cursor: pointer;
		font-family: var(--font-mono);
		font-size: 0.64rem;
		padding: 7px 11px;
		transition: border-color 180ms ease, background 180ms ease, color 180ms ease;
	}

	.install-tab:hover {
		border-color: var(--line-strong);
		color: var(--ink-soft);
	}

	.install-radio:focus-visible + .install-tab {
		outline: 2px solid var(--cyan);
		outline-offset: 2px;
	}

	.install-radio:checked + .install-tab {
		border-color: rgba(255, 99, 82, 0.7);
		background: rgba(255, 99, 82, 0.1);
		color: var(--coral);
	}

	.install-panels {
		flex-basis: 100%;
		margin-top: 7px;
	}

	.install-panel {
		display: none;
	}

	.install-radio-brew:checked ~ .install-panels .install-panel-brew {
		display: block;
	}

	.install-radio-manual:checked ~ .install-panels .install-panel-manual {
		display: grid;
	}

	.install-caption {
		margin: 0 0 7px;
		color: var(--cyan);
		font-family: var(--font-mono);
		font-size: 0.62rem;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}

	.install-command {
		display: block;
		width: 100%;
		overflow-x: auto;
		border: 1px solid var(--line);
		background: rgba(2, 11, 17, 0.72);
		color: #b7d4dc;
		font-family: var(--font-mono);
		font-size: 0.68rem;
		line-height: 1.5;
		padding: 14px 15px;
		white-space: nowrap;
	}

	.install-command span {
		color: var(--cyan);
	}

	.install-panel-manual {
		grid-template-columns: minmax(0, 1fr);
		gap: 10px;
	}

	.manual-download {
		display: inline-flex;
		justify-self: start;
		min-height: 43px;
		align-items: center;
		gap: 8px;
		border: 1px solid var(--line-strong);
		border-radius: 4px;
		color: var(--ink-soft);
		font-family: var(--font-mono);
		font-size: 0.68rem;
		padding-inline: 13px;
		transition: border-color 180ms ease, background 180ms ease, color 180ms ease;
	}

	.manual-download:hover {
		border-color: var(--cyan);
		background: var(--cyan-wash);
		color: var(--cyan-bright);
	}

	.manual-download svg {
		width: 16px;
		height: 16px;
		fill: none;
		stroke: currentColor;
		stroke-linecap: round;
		stroke-linejoin: round;
		stroke-width: 1.8;
	}

	.install-meta {
		margin: 11px 0 0;
		color: var(--ink-faint);
		font-family: var(--font-mono);
		font-size: 0.64rem;
	}

	@media (max-width: 640px) {
		.install-command {
			overflow-wrap: anywhere;
			white-space: normal;
		}

		.manual-download {
			justify-content: center;
			justify-self: stretch;
		}
	}
</style>
