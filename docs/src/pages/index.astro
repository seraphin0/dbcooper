---
import "../styles/global.css";
import "../styles/landing.css";
import appIconUrl from "../../../src-tauri/icons/icon.png?url";
import FAQ from "../components/FAQ.astro";
import Features from "../components/Features.astro";
import RoadmapMap from "../components/RoadmapMap.astro";
import SEO from "../components/SEO.astro";

const year = new Date().getFullYear();
const downloadUrl = "https://github.com/amalshaji/dbcooper/releases/latest";
const sourceUrl = "https://github.com/amalshaji/dbcooper";
const latestReleaseApiUrl = "https://api.github.com/repos/amalshaji/dbcooper/releases/latest";
const starsApiUrl = "https://github-stars.amalshaji.workers.dev/";
const fallbackStarCount = 456;
const installCommand = "brew install --cask --force amalshaji/taps/dbcooper";
const quarantineCommand = "xattr -cr /Applications/DBcooper.app";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href={appIconUrl} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<SEO />
	</head>
	<body>
		<a class="skip-link" href="#main-content">Skip to content</a>

		<header class="site-header">
			<div class="site-shell header-material">
				<a href="#top" class="brand" aria-label="DBcooper home">
					<img src={appIconUrl} alt="" width="36" height="36" />
					<span>DBcooper</span>
				</a>

				<nav aria-label="Primary navigation">
					<a href="#features">Features</a>
					<a href="#roadmap">Roadmap</a>
					<a class="github-link" href={sourceUrl} target="_blank" rel="noreferrer">
						<span>GitHub</span>
						<span
							class="github-stars"
							aria-label={`${fallbackStarCount} stars`}
							data-github-stars
							data-stars-endpoint={starsApiUrl}
						>
							<svg viewBox="0 0 24 24" aria-hidden="true">
								<path d="m12 3 2.7 5.5 6.1.9-4.4 4.3 1 6.1-5.4-2.9-5.4 2.9 1-6.1-4.4-4.3 6.1-.9Z"></path>
							</svg>
							<span data-github-star-count>{fallbackStarCount}</span>
						</span>
					</a>
				</nav>

				<a class="primary-action header-download" href="#install">
					<svg viewBox="0 0 24 24" aria-hidden="true">
						<path d="m5 7 5 5-5 5m7 0h7"></path>
					</svg>
					<span>Install with Homebrew</span>
				</a>
			</div>
		</header>

		<main>
			<section id="top" class="hero">
				<div class="site-shell hero-copy">
					<h1>Talk to your databases.</h1>
					<p>
						A fast, beautiful client for PostgreSQL, SQLite, Redis &amp; ClickHouse. Browse data, run
						SQL, visualize schemas — or just describe what you need and let AI write the query.
					</p>

					<div class="hero-actions">
						<a class="primary-action" href="#install">
							<svg viewBox="0 0 24 24" aria-hidden="true">
								<path d="m5 7 5 5-5 5m7 0h7"></path>
							</svg>
							<span>Install with Homebrew</span>
						</a>
						<a class="source-action" href={downloadUrl} target="_blank" rel="noreferrer">
							Download .dmg
							<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3v12m0 0 5-5m-5 5-5-5M5 21h14"></path></svg>
						</a>
					</div>

					<p class="database-line">PostgreSQL <span>·</span> SQLite <span>·</span> Redis <span>·</span> ClickHouse</p>
				</div>

				<div class="product-stage" aria-label="DBcooper application preview">
					<div class="data-plane" aria-hidden="true"></div>
					<div class="hero-icon" aria-hidden="true">
						<img src={appIconUrl} alt="" width="128" height="128" />
					</div>
					<figure class="hero-window">
						<img
							src="/screenshots/simple-dark.webp"
							alt="DBcooper browsing and filtering a SQLite table"
							width="2696"
							height="1736"
							loading="eager"
							fetchpriority="high"
						/>
					</figure>
				</div>
			</section>

			<section id="main-content" class="product-tour site-shell" aria-labelledby="tour-title">
				<header class="tour-heading">
					<h2 id="tour-title">Query, explore, and understand your data in one place.</h2>
				</header>

				<article class="tour-row">
					<div class="tour-copy">
						<h3>Write SQL with the schema close by.</h3>
						<p>Generate a contextual draft, inspect every statement, and choose exactly what enters the editor. Nothing runs without you.</p>
						<ul>
							<li>Schema-aware generation</li>
							<li>Streaming SQL previews</li>
							<li>Saved queries and history</li>
						</ul>
					</div>
					<figure class="app-window">
						<img src="/screenshots/query-dark.webp" alt="DBcooper SQL editor with a contextual query draft" width="2000" height="1252" loading="lazy" />
					</figure>
				</article>

				<article class="tour-row tour-row-reverse">
					<div class="tour-copy">
						<h3>See how the database fits together.</h3>
						<p>Turn foreign keys into an interactive relationship map, focus the canvas, and move from schema to table in one click.</p>
						<ul>
							<li>Interactive relationships</li>
							<li>Table and column filters</li>
							<li>Exportable schema views</li>
						</ul>
					</div>
					<figure class="app-window">
						<img src="/screenshots/visual-dark.webp" alt="DBcooper schema visualizer showing related tables" width="2000" height="1252" loading="lazy" />
					</figure>
				</article>
			</section>

			<div class="site-shell content-index">
				<RoadmapMap />
				<Features />
				<FAQ />
			</div>

			<section id="install" class="download-section">
				<div class="site-shell download-panel">
					<div>
						<h2>Open the database.<br />Skip the ceremony.</h2>
						<p class="download-meta">
							<span>Free, open source, and built for Apple Silicon.</span>
							<a
								class="version-badge"
								href={downloadUrl}
								target="_blank"
								rel="noreferrer"
								data-latest-version
								data-release-endpoint={latestReleaseApiUrl}
							>
								Latest release
							</a>
						</p>
					</div>

					<div class="download-options">
						<div class="install-option install-option-primary">
							<div class="install-option-heading">
								<strong>Homebrew</strong>
								<span>Recommended</span>
							</div>
							<div class="install-command" aria-label="Homebrew installation command">
								<span aria-hidden="true">$</span>
								<code>{installCommand}</code>
								<button type="button" data-copy-command={installCommand} data-copy-name="Homebrew">Copy</button>
							</div>
							<p>Installs DBcooper and clears Gatekeeper quarantine automatically.</p>
						</div>

						<div class="install-option install-option-secondary">
							<div class="install-option-heading">
								<strong>Direct download</strong>
								<a href={downloadUrl} target="_blank" rel="noreferrer">
									Download .dmg
									<svg viewBox="0 0 24 24" aria-hidden="true">
										<path d="M12 3v12m0 0 5-5m-5 5-5-5M5 21h14"></path>
									</svg>
								</a>
							</div>
							<p>After moving DBcooper to Applications, run this once:</p>
							<div class="install-command" aria-label="Gatekeeper quarantine removal command">
								<span aria-hidden="true">$</span>
								<code>{quarantineCommand}</code>
								<button type="button" data-copy-command={quarantineCommand} data-copy-name="xattr">Copy</button>
							</div>
						</div>
						<p class="copy-status" aria-live="polite" data-copy-status></p>
					</div>
				</div>
			</section>
		</main>

		<footer>
			<div class="site-shell footer-inner">
				<a href="#top" class="brand" aria-label="Back to top">
					<img src={appIconUrl} alt="" width="28" height="28" />
					<span>DBcooper</span>
				</a>
				<p>© {year} · MIT licensed · Built for developers who live in data.</p>
				<a href={sourceUrl} target="_blank" rel="noreferrer">Source code ↗</a>
			</div>
		</footer>

		<script>
			const copyButtons = document.querySelectorAll("[data-copy-command]");
			const copyStatus = document.querySelector("[data-copy-status]");
			const starsBadge = document.querySelector("[data-github-stars]");
			const starsCount = starsBadge?.querySelector("[data-github-star-count]");
			const starsEndpoint = starsBadge?.getAttribute("data-stars-endpoint");
			const versionBadge = document.querySelector("[data-latest-version]");
			const releaseEndpoint = versionBadge?.getAttribute("data-release-endpoint");

			for (const copyButton of copyButtons) {
				copyButton.addEventListener("click", async () => {
					const command = copyButton.getAttribute("data-copy-command");
					const commandName = copyButton.getAttribute("data-copy-name");
					if (!command) return;

					try {
						await navigator.clipboard.writeText(command);
						copyButton.textContent = "Copied";
						if (copyStatus) copyStatus.textContent = `${commandName} command copied`;
					} catch {
						copyButton.textContent = "Copy manually";
						if (copyStatus) copyStatus.textContent = "Copy failed. Select the command and copy it manually.";
					}

					window.setTimeout(() => {
						copyButton.textContent = "Copy";
					}, 2500);
				});
			}

			if (starsBadge && starsCount && starsEndpoint) {
				fetch(starsEndpoint)
					.then((response) => {
						if (!response.ok) throw new Error("Unable to load GitHub stars");
						return response.json();
					})
					.then((data) => {
						const count = data?.["amalshaji/dbcooper"]?.stars;
						if (!Number.isInteger(count) || count < 0) return;

						starsCount.textContent = new Intl.NumberFormat("en-US").format(count);
						starsBadge.setAttribute("aria-label", `${count} stars`);
					})
					.catch(() => {});
			}

			if (versionBadge && releaseEndpoint) {
				fetch(releaseEndpoint, {
					headers: { Accept: "application/vnd.github+json" },
				})
					.then((response) => {
						if (!response.ok) throw new Error("Unable to load the latest release");
						return response.json();
					})
					.then((release) => {
						if (typeof release?.tag_name !== "string" || !release.tag_name) return;

						versionBadge.textContent = `Latest ${release.tag_name}`;
						versionBadge.setAttribute("aria-label", `Latest release ${release.tag_name}`);
					})
					.catch(() => {});
			}
		</script>
		{import.meta.env.PROD && <script async src="https://scripts.simpleanalyticscdn.com/latest.js"></script>}
	</body>
</html>
